# Copy to .env.sepolia and fill in values. Do not commit .env.sepolia.
# Usage: source .env.sepolia  (then run ./scripts/deploy_sepolia.sh or sozo -P sepolia migrate)

export STARKNET_RPC_URL=https://api.cartridge.gg/x/starknet/sepolia
export DOJO_ACCOUNT_ADDRESS=0x_your_deployed_account_address
export DOJO_PRIVATE_KEY=0x_your_private_key

# Optional: STRK token address for Sepolia. If set, deploy script will call initialize_coin_shop (or update_exchange_rate if already initialized).
# export STRK_TOKEN_ADDRESS=0x_stark_token_sepolia_address
